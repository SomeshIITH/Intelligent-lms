# ==============================================================================
# Intelligent LMS - Production Environment Configuration Template
# ==============================================================================

# Application Host and Port Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Core AI Credentials
# Get your key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Persistent Storage Configurations (Relative to project root or Absolute Paths)
UPLOAD_DIR=uploads
CHROMA_DB_DIR=chroma_db

# Security & CORS settings (Comma-separated origins for production safety)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging Configurations
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=1 week